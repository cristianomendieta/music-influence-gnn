   note 	= {},
   number	= {},
   month	= {Junho},
   year		= {1997}
}

%%%%% exemplo de artigo em revista
@article{Awerbuch85a,
   author	= {B. Awerbuch},
   title	= {Complexity of network synchronization},
   journal	= {Journal of ACM},
   volume	= {32},
   number	= {4},
   pages	= {801-823},
